---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import RingMark from "../components/RingMark.astro";

const capabilities = [
  { label: "Schedule", text: "Meetings, reminders, and follow-ups — handled the moment you say them, not typed into a form." },
  { label: "Travel", text: "Full itineraries: flights, hotels, and ground transport, planned around how you actually like to travel." },
  { label: "Memory", text: "Nosaka remembers your preferences, so you stop having to repeat yourself." },
];
---

<Layout
  title="nosaka.ai — Executive assistant agent"
  description="Nosaka is a voice-first executive assistant built on AI."
>
  <Header current="home" />

  <main>
    <div class="hero-band">
      <section class="hero wrap">
        <div class="hero-copy">
          <p class="eyebrow"><span class="dot"></span>Voice-first &middot; Private beta</p>
          <h1>Executive assistant agent, exponentially increase your productivity with the simplicity of natural dialogue.</h1>
          <p class="sub">Nosaka is a super intelligent assistant that takes care of your asks.  Built on top of leading AI technology, Nosaka adapts to your preferences and mood to provide the best experience for those that demand excellence.</p>
          <div class="cta-row">
            <a class="btn" href="mailto:hello@nosaka.ai?subject=Early%20access">Request access</a>
            <span class="cta-note">Currently in private testing.</span>
          </div>
        </div>
        <div class="hero-mark">
          <RingMark frame />
        </div>
      </section>
    </div>

    <section class="capabilities wrap" id="about">
      {capabilities.map((c) => (
        <div class="cap-row">
          <div class="cap-label">{c.label}</div>
          <p class="cap-text">{c.text}</p>
        </div>
      ))}
    </section>

    <section class="access">
      <div class="wrap">
        <h2>Nosaka is in private testing.</h2>
        <p>Request access and we'll reach out when there's room.</p>
        <div class="cta-row">
          <a class="btn" href="mailto:hello@nosaka.ai?subject=Early%20access">Request access</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

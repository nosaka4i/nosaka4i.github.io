---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title="Blog — Nosaka"
  description="Notes on building a voice-first executive assistant."
>
  <Header current="blog" />
  <main>
    <div class="page-hero wrap">
      <h1>Blog</h1>
      <p class="lede">Notes on building Nosaka — design decisions, what's changed, and why.</p>
    </div>

    {posts.length === 0 ? (
      <p class="post-empty wrap">Nothing here yet.</p>
    ) : (
      <div class="post-list wrap">
        {posts.map((post) => (
          <a class="post-row" href={`/blog/${post.id}/`}>
            <span class="post-date">
              {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            </span>
            <div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
  <Footer />
</Layout>
